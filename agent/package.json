{
  "name": "orion-agent",
  "version": "1.0.0",
  "description": "ORION NMS — agent desktop Windows/Linux (metriques CPU/RAM)",
  "author": "ORION NMS",
  "main": "electron/main.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "electron-dev": "concurrently -k -n vite,electron -c blue,magenta \"vite\" \"node electron/launch.cjs\"",
    "electron": "electron .",
    "build": "vite build",
    "start": "npm run build && electron .",
    "dist": "npm run build && node ./node_modules/electron-builder/cli.js --win",
    "dist:portable": "npm run build && node ./node_modules/electron-builder/cli.js --win portable"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "electron-store": "^10.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "systeminformation": "^5.23.5",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.orion.nms.agent",
    "productName": "ORION Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "ORION Agent"
    }
  }
}
